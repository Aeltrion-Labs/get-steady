{
  "name": "get-steady",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first desktop app for building a steady daily money habit.",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "format": "prettier --write . --ignore-unknown && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all",
    "format:check": "prettier --check . --ignore-unknown && cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all --check",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.44.1"
  }
}
